# ---------------------------------------------------------------
# Workhuman Web Dashboard - environment template
# Copy this file to .env and fill in the real values.
# Never commit .env or service-account.json to git.
# ---------------------------------------------------------------

# Google Analytics 4 (service account)
# Path is relative to project root. The JSON file is what you download from
# Google Cloud > IAM > Service Accounts > Keys > Add Key (JSON).
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# GA4 property IDs (numeric only, no "properties/" prefix)
GA4_PROPERTY_ID_WORKHUMAN_COM=
GA4_PROPERTY_ID_WORKHUMAN_LIVE=

# Profound API
# Generate at: app.tryprofound.com > your profile > API Keys
PROFOUND_API_KEY=h-j0QpCuGS0MMVclx71r0
PROFOUND_ORG_ID=
# Comma-separated list of domains tracked in your Profound workspace
PROFOUND_DOMAINS=workhuman.com

# Snapshot config
# How many days of history to retain in data/snapshots/
SNAPSHOT_RETENTION_DAYS=90
# Lookback window for "current" KPIs (e.g. 7 = last 7 days vs prior 7)
KPI_LOOKBACK_DAYS=7
