# Workhuman Dashboard (hosted Next.js version)
# Copy to .env.local for local dev. For production, set these in Vercel
# (Project Settings → Environment Variables).

# =================================================================
# Auth (NextAuth)
# =================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# In dev: http://localhost:3000
# In prod: https://workhuman-dashboard.vercel.app (or your custom domain)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
# Application type: Web
# Authorized JS origin: <NEXTAUTH_URL>
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of email domains permitted to sign in (case-insensitive).
# Default is workhuman.com so only Workhuman teammates can authenticate.
ALLOWED_EMAIL_DOMAINS=workhuman.com

# =================================================================
# Snapshot storage (Vercel Blob)
# =================================================================
# Auto-injected when you add a Blob store to the project on Vercel.
# Leave blank locally to fall back to the legacy on-disk snapshot
# under ../data/snapshot.json.
BLOB_READ_WRITE_TOKEN=

# =================================================================
# Cron auth
# =================================================================
# Random string. Vercel Cron sends `Authorization: Bearer <CRON_SECRET>`
# on every scheduled invocation of /api/refresh. Without this, the cron
# endpoint cannot run (it would be 401).
# Generate with: openssl rand -hex 32
CRON_SECRET=

# =================================================================
# Google service account (GA4 + GSC)
# =================================================================
# LOCAL DEV: point at the JSON file on disk.
GOOGLE_APPLICATION_CREDENTIALS=../credentials/service-account.json
# PROD (Vercel): paste the full service-account JSON here, base64 encoded.
# Generate with:  base64 -i credentials/service-account.json | pbcopy
# On Vercel, leave GOOGLE_APPLICATION_CREDENTIALS unset and only set the
# JSON env var below. The app decodes it to /tmp at runtime.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# =================================================================
# Data source configuration
# =================================================================
GA4_PROPERTY_ID_WORKHUMAN_COM=
GA4_PROPERTY_ID_WORKHUMAN_LIVE=
PROFOUND_API_KEY=
PROFOUND_DOMAINS=workhuman.com
GSC_SITE_URL=sc-domain:workhuman.com
INCLUDE_HOSTNAMES=www.workhuman.com,workhuman.com,press.workhuman.com
WHLP_HOSTNAMES=whlp.workhuman.com
KPI_LOOKBACK_DAYS=30
EXCLUDE_PATH_PREFIXES=/speakers,/agenda,/forum,/events
